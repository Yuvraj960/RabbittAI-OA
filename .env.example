# ============================================================
# Sales Insight Automator — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# --- Backend ---
# A strong random secret key for API authentication
# Generate with: openssl rand -hex 32
API_SECRET_KEY=your_strong_random_secret_key_here

# Google Gemini API Key (get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP credentials
# Gmail address to send emails FROM
GMAIL_USER=your_gmail_address@gmail.com
# 16-character App Password (Google Account → Security → 2-Step Verification → App Passwords)
GMAIL_APP_PASSWORD=your_16_char_app_password

# --- Frontend ---
# The base URL of your backend API (change for production)
NEXT_PUBLIC_API_URL=http://localhost:8000
# The API key the frontend sends in X-API-Key header (same as API_SECRET_KEY)
NEXT_PUBLIC_API_KEY=your_strong_random_secret_key_here

# --- Optional: CORS Origins ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
